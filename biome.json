{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "files": {
    "ignore": [
      "node_modules",
      ".next",
      "out",
      "*.lock",
      "next-env.d.ts",
      "tsconfig.json",
      ".devcontainer",
      "package-lock.json"
    ]
  }
}
